{
  "name": "selenium-to-playwright-migrator",
  "version": "1.0.0",
  "description": "A tool to migrate Selenium Java test code to TypeScript Playwright",
  "main": "dist/index.js",
  "bin": {
    "sel2pw": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "migrate": "node dist/index.js"
  },
  "keywords": [
    "selenium",
    "playwright",
    "migration",
    "java",
    "typescript",
    "testing"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "glob": "^10.3.0"
  }
}
